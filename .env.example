# 运行模式。开发态会启用本机端口、Vite dev server 和更宽松的调试路径。
NODE_ENV=development
# 反向代理统一入口，Docker 全量启动时通常访问 http://localhost:8080。
PUBLIC_APP_URL=http://localhost:8080
# Nest API 监听端口，本机 pnpm dev 和 Docker compose 都会用到。
API_PORT=3000
# Vite dev server 端口；Docker web 容器会把 nginx:80 映射到该端口。
WEB_PORT=5173

# PostgreSQL 初始化数据库名、用户名和密码。第一次创建数据卷时生效。
POSTGRES_DB=rtclive
POSTGRES_USER=rtclive
POSTGRES_PASSWORD=rtclive_password
# 本机开发模式：apps/api 由 pnpm dev 跑在宿主机，通过 Docker 映射端口访问 Postgres。
# 全 Docker 模式：api 容器会在 docker-compose.yml 中覆盖为 postgres:5432。
DATABASE_URL=postgresql://rtclive:rtclive_password@localhost:15432/rtclive?schema=public

# 本机开发模式：apps/api 由 pnpm dev 跑在宿主机，通过 Docker 映射端口访问 Redis。
# 全 Docker 模式：api 容器会在 docker-compose.yml 中覆盖为 redis:6379。
REDIS_URL=redis://localhost:16379

# JWT 密钥生产环境必须改成至少 32 位随机字符串，且 access/refresh 不应相同。
JWT_ACCESS_SECRET=replace-with-at-least-32-random-chars
JWT_REFRESH_SECRET=replace-with-another-32-random-chars
# access token 保持短 TTL，refresh token 由数据库哈希记录支持撤销。
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# 发给浏览器使用的 LiveKit 地址。same-origin 会走当前 Web 域名下的 /rtc 代理。
LIVEKIT_URL=same-origin
# 本机开发模式用 localhost；全 Docker 模式下 api 容器会覆盖为 http://livekit:7880。
LIVEKIT_SERVER_URL=http://localhost:7880
# LiveKit API key/secret 必须和 livekit 容器的 LIVEKIT_KEYS 保持一致。
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# LiveKit join token 的有效期，单位秒。
LIVEKIT_TOKEN_TTL_SECONDS=7200
# LiveKit 在 WebRTC ICE 候选里对浏览器公布的宿主机地址。
# 只在本机访问时可以保持 127.0.0.1；用局域网 IP 访问时改成服务器/宿主机 IP，例如 192.168.80.6。
LIVEKIT_NODE_IP=127.0.0.1

# 本机开发模式用 localhost；全 Docker 模式下 api 容器会覆盖为 minio。
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
# MinIO 根账号；生产环境请替换为强随机值并限制网络访问。
MINIO_ACCESS_KEY=rtclive
MINIO_SECRET_KEY=rtclive_minio_password
# 业务文件和白板图片统一放在该 bucket 下。
MINIO_BUCKET=rtclive
MINIO_USE_SSL=false
# 发给浏览器的对象存储公开地址；Docker/Caddy 部署时可改成同源 /objects 入口。
MINIO_PUBLIC_URL=http://localhost:9000

# 已结束会议的保留天数，CleanupService 每天凌晨根据该值标记过期会议。
RETENTION_DAYS=30
# 单文件上传上限，单位字节；默认 200MB。
MAX_UPLOAD_BYTES=209715200
